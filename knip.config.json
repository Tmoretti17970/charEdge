{
    "$schema": "https://unpkg.com/knip@latest/schema.json",
    "entry": [
        "src/main.jsx",
        "server/**/*.js"
    ],
    "project": [
        "src/**/*.{js,jsx,ts,tsx}",
        "server/**/*.{js,ts}"
    ],
    "ignore": [
        "src/__tests__/**",
        "src/**/*.test.*",
        "src/**/*.spec.*"
    ],
    "ignoreDependencies": [
        "@vitejs/plugin-react",
        "eslint-*"
    ]
}