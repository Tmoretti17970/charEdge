        "Double Bottom",
        "Triangle",
        "Flag",
        "Head & Shoulders",
        "Cup & Handle"
      ],
      "featureSource": "Raw OHLCV candles (50-bar window)"
    },
    "setup-quality": {
      "name": "Setup Quality Predictor",
      "file": "setup_quality_v1.onnx",
