{
  "name": "charedge",
  "version": "11.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ssr": "node server.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/entry-server.jsx --outDir dist/server",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server.js",
    "serve": "NODE_ENV=production node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "npx playwright test",
    "lint": "eslint src/",
    "lint:css": "stylelint 'src/**/*.css' --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,json}\"",
    "audit": "npm audit --production --audit-level=high",
    "check": "npm run lint && npm run format:check && npm run test && npm run audit",
    "docker:build": "docker build -t charedge .",
    "docker:run": "docker run -p 3000:3000 charedge",
    "docs:api": "typedoc",
    "analyze": "npx -y vite-bundle-visualizer",
    "deploy:staging": "vercel --local-config vercel.staging.json",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@msgpack/msgpack": "^3.1.3",
    "@sentry/browser": "^10.42.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-virtual": "^3.13.22",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.4.0",
    "chartjs-plugin-zoom": "^2.2.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",

    "express": "^4.21.0",
    "flexlayout-react": "^0.7.0",
    "framer-motion": "^12.34.3",
    "isomorphic-dompurify": "^3.0.0",
    "lucide-react": "^0.577.0",
    "posthog-js": "^1.358.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.0.0",
    "@webgpu/types": "^0.1.69",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "madge": "^8.0.0",
    "prettier": "^3.4.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^37.0.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "react-refresh": "0.14.2"
  }
}
