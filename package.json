{
  "name": "charedge",
  "version": "11.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ssr": "node server.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/entry-server.jsx --outDir dist/server",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server.js",
    "serve": "NODE_ENV=production node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "npx playwright test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,json}\"",
    "audit": "npm audit --production --audit-level=high",
    "check": "npm run lint && npm run format:check && npm run test && npm run audit",
    "docker:build": "docker build -t charedge .",
    "docker:run": "docker run -p 3000:3000 tradeforge"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "chart.js": "^4.4.0",
    "chartjs-plugin-zoom": "^2.2.0",
    "compression": "^1.7.4",
    "dexie": "^4.0.0",
    "express": "^4.21.0",
    "flexlayout-react": "^0.7.0",
    "framer-motion": "^12.34.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^15.14.0",
    "prettier": "^3.4.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
