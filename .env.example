# ═══════════════════════════════════════════════════════════════════
# charEdge v11 — Environment Variables
# Copy to .env.local for local development
#
# ⚠️  SECURITY RULES:
#   - VITE_* variables are compiled into the client JS bundle.
#     Only use VITE_* for public/non-secret values.
#   - Exchange API keys use SERVER_* prefix (server-only, never in client).
#   - Supabase ANON key and PostHog/Sentry keys are designed
#     for client-side use and are safe as VITE_* variables.
# ═══════════════════════════════════════════════════════════════════

# Server
PORT=5173
HOST=0.0.0.0
NODE_ENV=development

# Set to true ONLY when behind a reverse proxy (Nginx, Cloudflare, Fly.io)
# TRUST_PROXY=false

# Site URL (used for SEO meta tags)
VITE_SITE_URL=https://charedge.app

# ─── Exchange API Keys (SERVER-ONLY — never prefixed with VITE_) ──
# These are read by server.js proxy routes only.
# SERVER_BINANCE_API_KEY=
# SERVER_BINANCE_SECRET=
# SERVER_ALPACA_KEY_ID=
# SERVER_ALPACA_SECRET=
# FMP_API_KEY=
# FRED_API_KEY=
# FINNHUB_API_KEY=
# TIINGO_API_TOKEN=

# Optional: Database (when you add persistence)
# DATABASE_URL=postgresql://user:pass@localhost:5432/charedge
# REDIS_URL=redis://localhost:6379

# Optional: Auth provider (anon key is safe for client-side)
# VITE_AUTH_PROVIDER=supabase
# VITE_SUPABASE_URL=https://xxx.supabase.co
# VITE_SUPABASE_ANON_KEY=

# Optional: Analytics (these keys are public/client-safe by design)
# VITE_POSTHOG_KEY=
# VITE_SENTRY_DSN=

# ─── Stripe Billing (SERVER-ONLY) ─────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_TRADER_PRICE_ID=price_...
# STRIPE_PRO_PRICE_ID=price_...
